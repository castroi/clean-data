# SECURITY: Never commit .env to version control. Set file permissions: chmod 600 .env

# Signal bot configuration
SIGNAL_PHONE_NUMBER=+972XXXXXXXXX

# These are set automatically by docker-compose, but can be overridden:
# SIGNAL_CLI_URL=http://signal-cli:8080
# TEMP_DIR=/tmp/clean-data

MAX_FILE_SIZE_MB=25
PROCESSING_TIMEOUT=300

# SECURITY: Uncomment and set ALLOWED_SENDERS to restrict who can use this service.
# Leaving this unset means ANY Signal user can send documents for processing.
# ALLOWED_SENDERS=+972501234567,+972509876543

# TTL for /replace word sessions in seconds (default: 3600 = 1 hour)
# WORD_SESSION_TTL_SECONDS=3600
